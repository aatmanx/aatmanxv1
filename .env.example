# =============================================================================
# Aatmanx Environment Variables
# =============================================================================
# Copy this file to `.env` in the project root and fill in your values.
# The application reads these automatically — no code changes required.
#
# Quick start:
#   1. cp .env.example .env
#   2. Paste your OpenAI API key on the OPENAI_API_KEY line
#   3. Ensure Supabase variables are set (see docs/SUPABASE_SETUP.md)
#   4. Restart the dev server: npm run dev
# =============================================================================

# --- OpenAI (required for AI content generation) ---------------------------
# Get your key at: https://platform.openai.com/api-keys
# Paste your key after the equals sign — no quotes needed.
OPENAI_API_KEY=

# Optional: override the default model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# --- Supabase (required for auth and database) -----------------------------
# Client-side (inlined into browser bundle at build time):
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side only (never expose to browser):
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Tip: VITE_* and unprefixed Supabase vars are usually the same URL/key pair.
# On Vercel, set all six variables in Project Settings → Environment Variables
# before deploying so the production build inlines the VITE_* values correctly.
